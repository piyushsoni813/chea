# ---------------------------------------------------------------------------
# CHEA backend environment.
# Copy to .env and adjust. Sensible local defaults mean a fresh clone boots
# without filling everything in; the values below mirror docker-compose.
# Stack: Postgres + FastAPI + NGINX (no Redis).
# ---------------------------------------------------------------------------

# --- Core ---
PROJECT_NAME=CHEA API
API_V1_PREFIX=/api/v1
ENVIRONMENT=development            # development | staging | production
DEBUG=true
# Generate a strong one for production, e.g. `openssl rand -hex 32`
SECRET_KEY=change-me-in-production-use-a-long-random-string

# --- Auth / JWT ---
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ALGORITHM=HS256
# Comma-separated. Only these email domains may self-register.
ALLOWED_EMAIL_DOMAINS=chea.edu,students.chea.edu

# --- Database ---
POSTGRES_HOST=db                  # 'localhost' when running outside Docker
POSTGRES_PORT=5432
POSTGRES_USER=chea
POSTGRES_PASSWORD=chea
POSTGRES_DB=chea
DB_ECHO=false

# --- CORS (comma-separated; '*' allows all) ---
BACKEND_CORS_ORIGINS=*

# --- Uploads ---
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=25
ALLOWED_UPLOAD_EXTENSIONS=.pdf,.png,.jpg,.jpeg,.webp,.doc,.docx

# --- Email (SMTP) — leave blank to log emails instead of sending ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@chea.edu
SMTP_TLS=true

# --- Google Sign-In — set to enable /auth/google ---
GOOGLE_CLIENT_ID=

# --- Firebase Cloud Messaging — path to service-account JSON to enable push ---
FCM_CREDENTIALS_PATH=

# --- First superuser, seeded on startup ---
FIRST_SUPERUSER_EMAIL=admin@chea.edu
FIRST_SUPERUSER_PASSWORD=admin12345

# --- Container entrypoint behaviour ---
SEED_ON_START=true
